# ── App ──────────────────────────────────────────
APP_NAME=trading-middleware
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key-change-this

# ── PostgreSQL ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_middleware
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=your_password
DATABASE_URL=postgresql+asyncpg://trading_user:your_password@localhost:5432/trading_middleware

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Alpaca (US Stocks) ────────────────────────────
# Get free API keys at https://alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper = test, use live URL for real trading
ALPACA_DATA_URL=https://data.alpaca.markets

# ── Binance (Crypto) ──────────────────────────────
# Get API keys at https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_TESTNET=true   # set false for live trading

# ── Risk Defaults ─────────────────────────────────
MAX_DAILY_LOSS_PCT=5.0
MAX_RISK_PER_TRADE_PCT=2.0
MAX_OPEN_TRADES=5
MAX_CRYPTO_POSITIONS_ISOLATED=3

# ── Candlestick Pattern Alerts ────────────────────
PATTERN_ALERT_ENABLED=true
PATTERN_MIN_CONFIDENCE=0.7
